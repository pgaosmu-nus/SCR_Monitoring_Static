echo "ïŋ―ïŋ―Į° Python Â·ïŋ―ïŋ―: $(which python)"
# ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―Į·ïŋ―ïŋ―ïŋ―Ð§
python -c "import sys; print('defualt code:', sys.getdefaultencoding())"
python --version
# ïŋ―ïŋ―ÖĪ PyTorch (sm_86 ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―)
python -c "import torch; print('PyTorch version:', torch.__version__); print('CUDA available:', torch.cuda.is_available()); print('GPU Spec:', torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'None')"
echo "=================================="

# 6. Öīïŋ―ïŋ―ïŋ―Ðūïŋ―ïŋ―ïŋ―ïŋ―ïŋ―
