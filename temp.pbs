# 1. ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―Ōĩïŋ―ïŋ―ïŋ―ïŋ―
#PBS -N Decoder_DD_Test
# ïŋ―Øžïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ÖŪĮ°ïŋ―ïŋ― qstat -qïŋ―ïŋ―ïŋ―ïŋ―Č·ïŋ―ïŋ― auto_free ïŋ―ïŋ―ïŋ―ïŋ―Ð§ïŋ―ïŋ―ïŋ―ÐĢïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ― Unknown Queueïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ÎŠ gpu
#PBS -q auto_free
# ïŋ―ïŋ―Ôīïŋ―ïŋ―ïŋ―ëĢšïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―čķĻïŋ―ïŋ― 6ïŋ―ïŋ―/50GB ïŋ―ïŋ―ïŋ―ïŋ―
#PBS -l select=1:ncpus=6:mpiprocs=1:ompthreads=6:mem=50gb:ngpus=1
#PBS -l walltime=24:00:00
#PBS -j oe

# 2. ïŋ―ïŋ―ïŋ―Ũ―ïŋ―ïŋ― UnicodeEncodeError (ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―Þļïŋ―)
# ïŋ―ïŋ―Öīïŋ―ïŋ―ïŋ―Îšïŋ― python ïŋ―ïŋ―ïŋ―ïŋ―Į°ïŋ―ïŋ―Įŋïŋ―ïŋ―ïŋ―čķĻïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ÎŠ UTF-8
export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8
export PYTHONIOENCODING=utf-8

# 3. ïŋ―ïŋ―ïŋ―ëđĪïŋ―ïŋ―ÄŋÂž
cd $PBS_O_WORKDIR

# 4. ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―
module purge
module load Python/3.11.3-GCCcore-12.3.0
module load CUDA/12.1.1 

# ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―ïŋ―
unset PYTHONHOME
